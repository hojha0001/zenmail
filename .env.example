# Copy to .env.local and fill in values
# Never commit .env.local to git

# Google OAuth (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Microsoft OAuth (from Azure portal)
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Anthropic (server-side only — Vercel env var, NOT VITE_ prefix)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App URL (your Vercel deployment URL)
VITE_APP_URL=https://zenmail.vercel.app
